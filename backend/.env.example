# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ichiban
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@db:5432/ichiban
POSTGRES_DB=ichiban
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production
